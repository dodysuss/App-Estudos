generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Course {
  id           String           @id @default(cuid())
  userId       String?
  user         User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  url          String?
  kind         String           @default("COURSE")
  folderId     String?
  folder       Folder?          @relation(fields: [folderId], references: [id], onDelete: SetNull)
  subject      String?
  tags         String[]         @default([])
  totalLessons Int
  lessons      Lesson[]
  modules      CourseModule[]
  studyNotes   StudyNote[]
  materials    CourseMaterial[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([kind])
  @@index([userId, kind])
  @@index([folderId])
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String         @unique
  passwordHash  String
  courses       Course[]
  sessions      AuthSession[]
  digitalAssets DigitalAsset[]
  folders       Folder[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Folder {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  scope         String
  parentId      String?
  parent        Folder?        @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children      Folder[]       @relation("FolderTree")
  courses       Course[]
  digitalAssets DigitalAsset[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([userId, scope, parentId, name])
  @@index([userId, scope])
  @@index([parentId])
}

model AuthSession {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Lesson {
  id           String        @id @default(cuid())
  courseId     String
  course       Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessonNumber Int
  position     Int           @default(0)
  title        String?
  moduleId     String?
  module       CourseModule? @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  completed    Boolean       @default(false)
  completedAt  DateTime?
  notes        String?
  rating       Int           @default(0)
  pinned       Boolean       @default(false)
  studyNotes   StudyNote[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([courseId, lessonNumber])
  @@index([moduleId])
  @@index([courseId, pinned, position])
  @@index([courseId, moduleId, position])
}

model CourseModule {
  id        String   @id @default(cuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  name      String
  position  Int
  lessons   Lesson[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([courseId, position])
  @@index([courseId])
}

model StudyNote {
  id               String                 @id @default(cuid())
  courseId         String
  course           Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessonId         String?                @unique
  lesson           Lesson?                @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  videoUrl         String?
  videoId          String?
  content          String?
  publishedContent String?
  publishedAt      DateTime?
  publications     StudyNotePublication[]
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
}

model StudyNotePublication {
  id          String    @id @default(cuid())
  studyNoteId String
  studyNote   StudyNote @relation(fields: [studyNoteId], references: [id], onDelete: Cascade)
  content     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([studyNoteId, createdAt])
}

model CourseMaterial {
  id         String   @id @default(cuid())
  courseId   String
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  fileName   String
  storedName String
  mimeType   String
  size       Int
  url        String
  createdAt  DateTime @default(now())

  @@index([courseId])
}

model DigitalAsset {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title            String
  description      String?
  folderId         String?
  folder           Folder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)
  tags             String[]  @default([])
  category         String?
  assetType        String    @default("Nota")
  content          String?
  publishedContent String?
  publishedAt      DateTime?
  coverImage       String?
  coverColor       String?
  pinned           Boolean   @default(false)
  favorite         Boolean   @default(false)
  archived         Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([userId, archived, pinned, updatedAt])
  @@index([userId, favorite])
  @@index([folderId])
  @@index([userId, category])
  @@index([userId, assetType])
}
