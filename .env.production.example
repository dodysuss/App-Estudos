# Nunca preencha este arquivo com senhas reais nem o renomeie dentro do Git.
# Configure os valores reais diretamente na Vercel.
DATABASE_URL="postgresql://postgres.[ref]:[SENHA]@aws-0-[regiao].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[SENHA]@aws-0-[regiao].pooler.supabase.com:5432/postgres"

# Opcional, mas recomendado para anexos/material didático permanente em produção.
# Crie um bucket público no Supabase Storage, por exemplo: app-estudos
SUPABASE_URL="https://[ref].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="[service-role-key]"
SUPABASE_STORAGE_BUCKET="app-estudos"
